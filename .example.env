# discovery-server
# APP
DISCOVERY_SERVER_NAME=discovery-server
DISCOVERY_PORT=8761
SPRING_SECURITY_USER_NAME=eureka
SPRING_SECURITY_USER_PASSWORD=<password>
#DISCOVERY_URL=http://localhost:8761/eureka
#DISCOVERY_AUTH_URL=http://eureka:<password>@localhost:8761/eureka
DISCOVERY_URL=http://discovery-server:8761/eureka
DISCOVERY_AUTH_URL=http://eureka:<password>@discovery-server:8761/eureka

# Keycloak
# APP
KEYCLOAK_VERSION=26.3.3
KEYCLOAK_PORT=8181
DB_VENDOR=POSTGRES
DB_ADDR=db-keyloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KC_HTTP_PORT=8181
#KEYCLOAK_ISSUER_URI=http://localhost:8181/realms/microservices-realm
#KEYCLOAK_JWT_URI=http://localhost:8181/realms/microservices-realm/protocol/openid-connect/certs
KEYCLOAK_ISSUER_URI=http://keycloak:8181/realms/microservices-realm
KEYCLOAK_JWT_URI=http://keycloak:8181/realms/microservices-realm/protocol/openid-connect/certs
KEYCLOAK_CLIENT_SECRET=UXi7lVHMgAggNHijux9q7RINhE4VcKrr
# DataBase
KEYCLOAK_POSTGRES_VERSION=12-alpine
#KEYCLOAK_SPRING_DATASOURCE_JDBC_URL=jdbc:postgresql://db-keyloak:5432/db_keyloak
KEYCLOAK_POSTGRES_DB=db_keyloak

# api-gateway
# APP
GATEWAY_SERVICE_NAME=api-gateway
GATEWAY_PORT=8080

# inventory-service
# APP
INVENTORY_SERVICE_NAME=inventory-service
PORT=0
# DataBase
POSTGRES_VERSION=16-alpine
POSTGRES_PORT=5432
INVENTORY_SPRING_DATASOURCE_JDBC_URL=jdbc:postgresql://db-inventory:5432/ms_inventory
POSTGRES_DB=ms_inventory
