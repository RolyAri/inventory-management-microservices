# inventory-service
# APP
INVENTORY_SERVICE_NAME=inventory-service
PORT=0
# DataBase
POSTGRES_VERSION=16-alpine
POSTGRES_PORT=5432
INVENTORY_SPRING_DATASOURCE_JDBC_URL=jdbc:postgresql://db-inventory:5432/ms_inventory
POSTGRES_DB=ms_inventory
