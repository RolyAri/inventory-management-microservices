DISCOVERY_PORT=8761
SPRING_SECURITY_USER_NAME=eureka
SPRING_SECURITY_USER_PASSWORD=<password>
#DISCOVERY_URL=http://localhost:8761/eureka
#DISCOVERY_AUTH_URL=http://eureka:<password>@localhost:8761/eureka
